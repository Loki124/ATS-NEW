# Database - MySQL 8
DATABASE_URL="mysql://ats:atspass@localhost:3306/ats"

# MySQL Connection (for entrypoint healthcheck)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=ats
MYSQL_PASSWORD=atspass
MYSQL_DATABASE=ats
MYSQL_ROOT_PASSWORD=rootpass

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=5125
NODE_ENV=development

# CORS
CORS_ORIGIN="http://localhost:5212"

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Rate Limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# Third-party Services
WECOM_WEBHOOK_URL=
EMAIL_SERVICE_URL=
SMS_SERVICE_URL=
