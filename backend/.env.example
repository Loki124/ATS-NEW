# Database - MySQL 8
# 注意：MySQL 9 默认密码策略要求大小写+数字+特殊字符
DATABASE_URL="mysql://ats:AtsPass2024!@127.0.0.1:3306/ats"

# MySQL Connection (for entrypoint healthcheck)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=ats
MYSQL_PASSWORD=AtsPass2024!
MYSQL_DATABASE=ats
MYSQL_ROOT_PASSWORD=your_root_password_here

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Server
# 开发: PORT=5125
# 生产（裸机 + Cloudflare Tunnel 直连）: PORT=9908
PORT=5125
NODE_ENV=development

# CORS
# 开发: http://localhost:5212
# 生产: 你的 Cloudflare 隧道域名，如 https://ats.example.com
CORS_ORIGIN="http://localhost:5212"

# 前端 dist 路径（可选；默认 ../../frontend/dist）
# Docker: FRONTEND_DIST=/app/frontend/dist
# 裸机: 不设
# FRONTEND_DIST=

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Rate Limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# Third-party Services
WECOM_WEBHOOK_URL=
EMAIL_SERVICE_URL=
SMS_SERVICE_URL=
