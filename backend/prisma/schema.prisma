  code           String  @unique
  permissionType String  @db.VarChar(32)
  resource       String?
  action         String?
  dataScope      String?

  parentId String?
  level    Int     @default(1)
  path     String?

  description String? @db.Text
  status      String  @default("ACTIVE") @db.VarChar(32)
