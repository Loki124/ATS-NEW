// ATS招聘管理系统 - 数据库模型
// 简历模块增强：双轨锁定人、异步评分、特殊审批

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// 简历锁定记录表 (核心新表)
// ============================================
model ResumeLockRecord {
  id       String @id @default(uuid())
  resumeId String
  lockerId String
  lockType String // FORMAL(正式锁定人), TEMPORARY(临时锁定人72h)

  effectiveTime DateTime  @default(now())
  expireTime    DateTime? // 仅临时锁定人有有效期
  isActive      Boolean   @default(true)

  source String // ASSIGN(分配), UPLOAD(上传), ACTIVATE(激活)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  locker User   @relation("ResumeLocker", fields: [lockerId], references: [id], onDelete: Restrict)

  @@index([resumeId, isActive])
  @@index([lockerId])
  @@map("resume_lock_records")
}

// ============================================
// 特殊标签关联表
// ============================================}
model SpecialResumeTag {
  id         String  @id @default(uuid())
  resumeId   String
  positionId String? // 标签与职位绑定，null表示全局

  tagName String @default("特殊简历")

  approvalId String? // 关联的审批单ID

  createdAt DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([resumeId, positionId])
  @@index([resumeId])
  @@map("special_resume_tags")
}

// ============================================
// 简历合并记录表
// ============================================}
model ResumeMergeRecord {
  id             String @id @default(uuid())
  mainResumeId   String // 主简历（保留）
  mergedResumeId String // 被合并简历

  mergeType String // MANUAL(主动合并), AUTO(超时自动合并)

  operatorId  String?
  mergeReason String?

  createdAt DateTime @default(now())

  mainResume   Resume @relation("MainResumeMerge", fields: [mainResumeId], references: [id], onDelete: Cascade)
  mergedResume Resume @relation("MergedResumeMerge", fields: [mergedResumeId], references: [id], onDelete: Cascade)

  @@unique([mergedResumeId])
  @@index([operatorId])
  @@map("resume_merge_records")
}

// ============================================
// 特殊审批流程表
// ============================================}
model SpecialApprovalFlow {
  id String @id @default(uuid())

  resumeId   String
  positionId String // 审批针对的职位

  flowType String @default("SPECIAL_RESUME") @db.VarChar(32) // SPECIAL_RESUME, OTHER

  status String @default("PENDING") @db.VarChar(32) // PENDING, APPROVED, REJECTED, CANCELLED

  currentNodeId String?

  // 各节点审批信息，JSON格式
  // [{nodeId, nodeName, approverId, approverName, status, comment, decidedAt}]
  nodes String @db.Text // JSON数组

  // 审批结果
  result        String?
  resultComment String?
  decidedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId, status])
  @@index([currentNodeId])
  @@map("special_approval_flows")
}

// ============================================
// 异步评分任务表
// ============================================}
model AsyncScoringTask {
  id String @id @default(uuid())

  resumeId   String
  positionId String // 评分针对的职位

  status String @default("PENDING") @db.VarChar(32) // PENDING, PROCESSING, COMPLETED, FAILED

  matchScore   Int?
  matchDetails String? @db.Text // JSON，评分详情

  errorMessage String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId, status])
  @@map("async_scoring_tasks")
}

// ============================================
// 简历流转日志表
// ============================================}
model ResumeFlowLog {
  id String @id @default(uuid())

  resumeId    String
  candidateId String

  action String // UPLOAD, ASSIGN, ARCHIVE, ACTIVATE, MERGE, SCORE, APPROVE, REJECT

  operatorId   String?
  operatorName String?

  fromStatus String?
  toStatus   String?

  positionId   String? // 关联职位（如果是分配相关）
  positionName String?

  detail String? @db.Text // JSON，额外详情

  createdAt DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@index([candidateId])
  @@index([operatorId])
  @@map("resume_flow_logs")
}

// ============================================
// 系统基础模块
// ============================================
model User {
  id           String    @id @default(uuid())
  username     String    @unique
  password     String
  realName     String
  email        String?   @unique
  phone        String?   @unique
  avatar       String?
  status       String    @default("ACTIVE") @db.VarChar(32)
  roleType     String    @default("HR") @db.VarChar(32)
  departmentId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  wechatWorkUserId String?
  wechatWorkDeptId String?
  wechatWorkName   String?

  mochaUserId String?
  mochaDeptId String?
  mochaName   String?

  permissionMode String @default("MOU") @db.VarChar(32)

  department Department? @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  userRoles           UserRole[]
  userDataPermissions UserDataPermission[]
  userMous            UserMou[]
  userContainers      UserContainer[]
  permissionAuditLogs PermissionAuditLog[]

  // 简历锁定关联
  lockedResumes ResumeLockRecord[] @relation("ResumeLocker")

  assignedCandidates Candidate[] @relation("CandidateAssignedUser")
  providedCandidates Candidate[] @relation("CandidateResumeProvider")

  // 内推门户 Phase 1 - 反向关系
  referralCode         ReferralCode?           @relation("UserReferralCode")
  referralExpertConfigs ReferralExpertConfig[] @relation("UserExpertConfigs")
  expertConfigs        ReferralExpertConfig[]  @relation("ExpertConfigs")
  referrerRecords      ReferralRecord[]        @relation("ReferrerRecords")
  expertRecords        ReferralRecord[]        @relation("ExpertRecords")
  rewardConfirmations  ReferralReward[]        @relation("RewardConfirmer")
  createdReferralRules ReferralRule[]          @relation("RuleCreator")

  // 招聘流程管理 - 反向关系
  createdProcesses    RecruitmentProcess[] @relation("ProcessCreator")
  updatedProcesses    RecruitmentProcess[] @relation("ProcessUpdater")
  createdRounds       InterviewRound[]     @relation("RoundCreator")
  updatedRounds       InterviewRound[]     @relation("RoundUpdater")

  @@index([departmentId])
  @@index([wechatWorkUserId])
  @@index([wechatWorkDeptId])
  @@index([mochaUserId])
  @@index([mochaDeptId])
  @@map("users")
}

model Department {
  id         String   @id @default(uuid())
  name       String
  code       String   @unique
  parentId   String?
  level      Int      @default(1)
  path       String
  managerId  String?
  manager2Id String?
  manager3Id String?
  hrbpId     String?
  status     String   @default("ACTIVE") @db.VarChar(32)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  parent   Department?  @relation("DepartmentTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Department[] @relation("DepartmentTree")

  users     User[]
  demands   Demand[]
  positions Position[]

  // 内推门户 Phase 1 - 反向关系
  expertConfigs ReferralExpertConfig[] @relation("TeamExpertConfigs")
  referralTeam  ReferralTeam?          @relation("DepartmentReferralTeam")

  @@index([parentId])
  @@index([managerId])
  @@index([manager2Id])
  @@index([manager3Id])
  @@index([hrbpId])
  @@map("departments")
}

model RecruitmentProcess {
  id              String   @id @default(uuid())
  name            String
  code            String   @unique
  description     String?  @db.Text
  applicableRange String?  // 旧字段保留 - 文本备注用
  status          String   @default("ACTIVE") @db.VarChar(32)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // ====== 新增字段 (2026-06-05) ======
  /// 适用范围 - 4 个维度 (#12.1)
  applicableDepartments    Json? // String[] - departmentId[]
  applicablePositionLevels Json? // String[]
  applicableUserIds        Json? // String[] - userId[]
  applicableJobs           Json? // String[]
  applicableMode String @default("ALL") @db.VarChar(16)

  /// Plan L: 适用范围 - 表达式驱动 (PRD #4 适用范围 5 条件 + 表达式)
  /// 结构: { items: [{ id, field, op, value, value2 }], expression: "(1 and 2) or (3 and 4)" }
  /// 5 条件字段: 请选择内容 / 需求部门 / 需求职级 / 登录人 / 职务
  applicableScope Json?

  /// 是否校验简历评分 (#10.2 #1463)
  validateResumeScore Boolean @default(true)

  /// 流转异常提示模板 (#3.3)
  failPrompt String? @db.Text

  /// 审计字段
  createdBy String?
  updatedBy String?

  creator User?            @relation("ProcessCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  updater User?            @relation("ProcessUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)

  links   ProcessStageLink[]
  stageRules StageRule[]
  conditions  EntryCondition[]
  autoRules  AutoArchiveRule[]

  positions Position[]

  @@map("recruitment_processes")
}

/// 招聘流程阶段 — 全局阶段模板库 (PRD #4)
/// 阶段编号: P + 3 位流水号（全局唯一，不属于任何流程）
/// 阶段类型: FILTER(筛选型) / INVITATION(邀约型) / INTERVIEW(面试型) / OFFER(Offer型) / ONBOARDING(入职型)
/// 业务规则:
///   - 系统预置阶段 (isSystem=true) 不可停用 / 删除
///   - 阶段被流程引用时不可停用 / 删除
///   - 起止阶段 (初评/正式录用) 是系统预置，所有流程共享
model RecruitmentStage {
  id                String   @id @default(uuid())
  code              String   @unique
  name              String
  stageType         String   @db.VarChar(32)
  stageLimit        Int?

  // ====== 新增字段 (2026-06-05) ======
  /// 功能项 (#4.3) - 支持的功能开关 JSON 数组
  /// 例如: ["INVITE_FILTER", "ARRANGE_INTERVIEW", "INVITE_INTERVIEW", "SEND_OFFER", "START_ONBOARDING", "START_BACKGROUND_CHECK", "INVITE_UPDATE_INFO", "TRANSFER_STAGE", "ARCHIVE"]
  features Json @default("[]")
  /// 是否为系统预置阶段 (初评/正式录用) - 不可停用
  isSystem Boolean @default(false)
  /// 阶段说明
  description String? @db.Text

  status    String   @default("ACTIVE") @db.VarChar(32)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// 哪些流程引用了这个阶段 - 通过 ProcessStageLink 关联
  links ProcessStageLink[]

  @@index([stageType, status])
  @@map("recruitment_stages")
}

/// 流程-阶段关联 (PRD #3.2)
/// 把全局阶段模板"应用"到具体流程中
/// 同一阶段在每个流程中只能添加一次 (#3.2 业务规则)
model ProcessStageLink {
  id        String  @id @default(uuid())
  processId String
  stageId   String

  /// 阶段顺序 (0-based) - #3.2 阶段顺序可在起止阶段之间自由排列
  orderIndex Int     @default(0)
  /// 阶段类型: SCREENING(筛选型) / INVITE(邀约型) / INTERVIEW(面试型) / ONBOARDING(入职型)
  /// Plan L: 冗余字段 - 便于在 link 列表上直接筛选/统计 (无需 join stage 表)
  stageType String @default("SCREENING") @db.VarChar(32)
  /// 流程内可自定义阶段名 (可选)
  customName String? @db.VarChar(64)
  /// 是否为该流程的起始阶段 (初评) - 通常是系统预置
  isStart    Boolean @default(false)
  /// 是否为该流程的结束阶段 (正式录用) - 通常是系统预置
  isEnd      Boolean @default(false)
  /// 阶段时长限制 (小时) - 从此 link 进入下一阶段的最大停留时间
  stageLimit Int?
  /// 状态 - 可单独停用 (不影响全局模板)
  status     String  @default("ACTIVE") @db.VarChar(32)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  process   RecruitmentProcess @relation(fields: [processId], references: [id], onDelete: Cascade)
  stage     RecruitmentStage   @relation(fields: [stageId], references: [id], onDelete: Restrict)
  rule      StageRule?
  condition EntryCondition?

  @@unique([processId, stageId])
  @@index([processId, orderIndex])
  @@map("process_stage_links")
}

model Demand {
  id             String @id @default(uuid())
  code           String @unique
  name           String
  departmentId   String
  positionCount  Int    @default(1)
  hiredCount     Int    @default(0)
  onBoardCount   Int    @default(0)
  demandType     String @db.VarChar(32)
  demandStatus   String @default("DRAFT") @db.VarChar(32)
  approvalStatus String @default("NOT_STARTED") @db.VarChar(32)

  creatorId       String
  managerId       String?
  assistantIds    String?
  managerIds      String?
  managerSuperIds String?
  hrbpId          String?

  positionSeries String?   @db.VarChar(32)
  jobTitle       String?
  jobLevel       String?   @db.VarChar(32)
  startDate      DateTime?
  endDate        DateTime?

  salaryMin Int?
  salaryMax Int?

  description  String? @db.Text
  requirements String? @db.Text
  attachments  String? @db.Text

  trialGoals String?

  talentLevel String? @db.VarChar(32)
  isDoubleA   Boolean @default(false)

  biddingMode         String   @default("BIDDING") @db.VarChar(32)
  biddingAmount       Decimal? @db.Decimal(12, 2)
  biddingUnit         String?  @db.VarChar(32)
  biddingTalentLevels String?

  status    String   @default("ACTIVE") @db.VarChar(32)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id])

  positions     Position[]
  approvalSteps DemandApprovalStep[]
  statusHistory DemandStatusHistory[]

  @@index([departmentId])
  @@index([creatorId])
  @@index([managerId])
  @@index([hrbpId])
  @@map("demands")
}

/// 需求审批步骤 - PRD G2 多级审批
/// 步骤状态机：WAITING (未到) → PENDING (待审批) → APPROVED (通过) / REJECTED (拒绝) / SKIPPED (跳过)
model DemandApprovalStep {
  id          String   @id @default(uuid())
  demandId    String
  stepIndex   Int      // 0-based
  approverRole String  @db.VarChar(32) // HRBP / MANAGER / MANAGER_SUPER / CHO
  approverId   String?  // null = 任何该角色的人
  status      String   @default("WAITING") @db.VarChar(32) // WAITING/PENDING/APPROVED/REJECTED/SKIPPED
  comment     String?  @db.Text
  approvedAt  DateTime?
  submittedBy String?  // 发起人
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  demand Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)

  @@unique([demandId, stepIndex])
  @@index([demandId, status])
  @@index([approverId, status])
  @@map("demand_approval_steps")
}

/// 通用操作审计日志 - 可被 Demand/Offer/入职/候选人 等所有状态机实体复用
/// (PRD G1+G2+G3.6+B.1)
/// 注: schema 已有同名 OperationRecord (line ~1102) 含更完整字段
/// (userName/targetName/beforeValue/afterValue/ipAddress/userAgent)
/// 此处不再重复定义,只声明 G1+G2+G3.6 用的子集 (DemandStatusHistory)

/// 通知队列 (PRD B.2 + G36 占位)
/// 触发: 审批状态变化、面试反馈待提交等
/// 发送: Phase 1-2 仅写入 + 日志,Phase 3 接企微/邮件后由 cron 拉表实际发送
model NotificationQueue {
  id           String   @id @default(uuid())
  recipientId  String                       // 接收人 userId
  templateKey  String   @db.VarChar(64)     // 模板 key
  title        String   @db.VarChar(255)
  content      String   @db.Text
  context      Json?                         // 渲染时用的变量
  priority     String   @default("NORMAL") @db.VarChar(16)  // LOW/NORMAL/HIGH
  status       String   @default("PENDING") @db.VarChar(16) // PENDING/SENT/READ/FAILED
  readAt       DateTime?
  sentAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([recipientId, status])
  @@index([status, priority])
  @@index([createdAt])
  @@map("notification_queues")
}

/// 通知模板 (PRD G36)
/// 通过 templateKey 索引,变量用 {{name}} 占位
/// 渠道: SYSTEM (站内) / EMAIL (邮件) / WECOM (企微) / SMS
model NotificationTemplate {
  id           String   @id @default(uuid())
  templateKey  String   @unique @db.VarChar(64)   // e.g. DEMAND_APPROVAL_PENDING
  name         String   @db.VarChar(128)          // 中文名,便于后台检索
  channel      String   @default("SYSTEM") @db.VarChar(16)  // SYSTEM/EMAIL/WECOM/SMS
  category     String   @db.VarChar(32)           // APPROVAL / INTERVIEW / OFFER / ONBOARDING / DEMAND
  title        String   @db.VarChar(255)          // 标题模板,支持 {{var}}
  content      String   @db.Text                  // 内容模板
  variables    Json?                              // 变量定义 [{name, type, required, description}]
  isActive     Boolean  @default(true)
  description  String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category, isActive])
  @@index([channel, isActive])
  @@map("notification_templates")
}

/// 需求状态变更历史（操作审计 + 状态机审计的合并视图）
/// (PRD B.1)
model DemandStatusHistory {
  id        String   @id @default(uuid())
  demandId  String
  fromStatus String? @db.VarChar(32)
  toStatus   String  @db.VarChar(32)
  reason     String? @db.Text
  operatorId String?
  createdAt  DateTime @default(now())

  demand Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)

  @@index([demandId, createdAt])
  @@map("demand_status_history")
}

/// 需求审批链配置 - PRD B.3 (可配置化审批流)
/// 按 (departmentId, positionLevel, 金额) 维度配置审批步骤
/// 匹配优先级: 三元组全匹配 > 二元匹配 > 通配 (NULL)
/// steps: [{ approverRole: 'HRBP' | 'MANAGER' | 'MANAGER_SUPER' | 'CHO', approverId: 'user-xxx' | null }, ...]
model DemandApprovalConfig {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(128)
  departmentId  String?  // NULL = 通配所有部门
  positionLevel String?  @db.VarChar(32) // NULL = 通配
  minAmount     Int?     // 适用金额下限 (cents), NULL = 不限
  maxAmount     Int?     // 适用金额上限
  steps         Json     // 步骤数组
  isActive      Boolean  @default(true)
  priority      Int      @default(0) // 多条匹配时优先级
  description   String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([departmentId, positionLevel, isActive])
  @@index([isActive, priority])
  @@map("demand_approval_configs")
}

model Position {
  id           String  @id @default(uuid())
  code         String  @unique
  name         String
  departmentId String
  demandId     String?

  creatorId       String
  managerId       String?
  assistantIds    String?
  managerIds      String?
  managerSuperIds String?

  priority       Int     @default(0)
  positionNature String? @db.VarChar(32)
  positionSeries String? @db.VarChar(32)
  description    String? @db.Text
  requirements   String? @db.Text

  processId String?
  companyId String?

  positionStatus String @default("RECRUITING") @db.VarChar(32)
  status         String @default("ACTIVE") @db.VarChar(32)

  candidateCount Int @default(0)
  hiredCount     Int @default(0)

  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  department Department          @relation(fields: [departmentId], references: [id])
  demand     Demand?             @relation(fields: [demandId], references: [id])
  process    RecruitmentProcess? @relation(fields: [processId], references: [id])

  applications Application[]
  channels     PositionChannel[]
  statusHistory PositionStatusHistory[]

  // 内推门户 Phase 1 - 反向关系
  referralRecords ReferralRecord[] @relation("PositionReferrals")

  @@index([departmentId])
  @@index([demandId])
  @@index([creatorId])
  @@index([managerId])
  @@index([processId])
  @@index([companyId])
  @@index([positionStatus])
  @@map("positions")
}

/// 职位状态变更历史 (PRD G5)
model PositionStatusHistory {
  id         String   @id @default(uuid())
  positionId String
  fromStatus String?  @db.VarChar(32)
  toStatus   String  @db.VarChar(32)
  reason     String?  @db.Text
  operatorId String?
  createdAt  DateTime @default(now())

  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([positionId, createdAt])
  @@map("position_status_history")
}

model PositionChannel {
  id             String    @id @default(uuid())
  positionId     String
  channelType    String    @db.VarChar(32)
  channelAccount String?
  publishStatus  String    @default("NOT_PUBLISHED")
  publishUrl     String?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([positionId])
  @@map("position_channels")
}

model Candidate {
  id       String    @id @default(uuid())
  code     String    @unique
  name     String
  gender   String?   @db.VarChar(32)
  birthday DateTime?
  phone    String?
  email    String?

  householdLocation String?
  originLocation    String?

  maritalStatus            String? @db.VarChar(32)
  childStatus              String? @db.VarChar(32)
  highestEducation         String?
  firstEducation           String?
  firstEducationDuration   Int?
  firstEducationSchoolType String?

  workExperience  String?
  jobHoppingRate  Int?
  lastJobDuration Int?

  educationForm     String?   @db.VarChar(32)
  expectedSalaryMin Int?
  expectedSalaryMax Int?
  expectedPosition  String?
  intendedJoinDate  DateTime?

  channelSource   String?
  channelLink     String?
  recommenderId   String?
  recommenderName String?

  assignedUserId   String?
  resumeProviderId String?

  assignedUser   User? @relation("CandidateAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  resumeProvider User? @relation("CandidateResumeProvider", fields: [resumeProviderId], references: [id], onDelete: SetNull)

  candidateStatus String  @default("ACTIVE") @db.VarChar(32)
  archiveReason   String?
  archiveType     String? @db.VarChar(32)
  archiveToPool   String?

  // G44 - 11 状态详细字段
  // 各子状态独立记录, 用于精细化分析 + 流程追踪
  // statusDetails = { evaluated: 'PENDING'|'PASS'|'FAIL', invite: 'PENDING'|'...', ... }
  statusDetails Json?  @db.Json

  protectionExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumes      Resume[]
  applications Application[]

  // 内推门户 Phase 1 - 反向关系
  referralRecords ReferralRecord[] @relation("CandidateReferrals")
  referralRewards ReferralReward[] @relation("CandidateReferralRewards")

  @@index([recommenderId])
  @@index([assignedUserId])
  @@index([resumeProviderId])
  @@map("candidates")
}

model Resume {
  id          String  @id @default(uuid())
  candidateId String
  positionId  String?

  name     String
  fileName String
  filePath String
  fileType String
  fileSize Int

  parsedData String? @db.Text

  source         String  @db.VarChar(32)
  uploadLocation String?
  providerId     String? // 提供人ID
  uploaderId     String? // 上传人ID
  channelSource  String?
  channelLink    String?

  resumeStatus    String  @default("PENDING_ASSIGN") @db.VarChar(32) // 待分配/已分配/已归档/已删除
  resumeSubStatus String? // 子状态：SCORING(评分中), APPROVAL(审批中), SUSPECTED(疑似)
  parseStatus     String  @default("PENDING") @db.VarChar(32)
  duplicateStatus String  @default("NOT_DUPLICATE") @db.VarChar(32)
  duplicateOfId   String?

