// ATS招聘管理系统 - 数据库模型
// 简历模块增强：双轨锁定人、异步评分、特殊审批

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// 简历锁定记录表 (核心新表)
// ============================================
model ResumeLockRecord {
  id       String @id @default(uuid())
  resumeId String
  lockerId String
  lockType String // FORMAL(正式锁定人), TEMPORARY(临时锁定人72h)

  effectiveTime DateTime  @default(now())
  expireTime    DateTime? // 仅临时锁定人有有效期
  isActive      Boolean   @default(true)

  source String // ASSIGN(分配), UPLOAD(上传), ACTIVATE(激活)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  locker User   @relation("ResumeLocker", fields: [lockerId], references: [id], onDelete: Restrict)

  @@index([resumeId, isActive])
  @@index([lockerId])
  @@map("resume_lock_records")
}

// ============================================
// 特殊标签关联表
// ============================================}
model SpecialResumeTag {
  id         String  @id @default(uuid())
  resumeId   String
  positionId String? // 标签与职位绑定，null表示全局

  tagName String @default("特殊简历")

  approvalId String? // 关联的审批单ID

  createdAt DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([resumeId, positionId])
  @@index([resumeId])
  @@map("special_resume_tags")
}

// ============================================
// 简历合并记录表
// ============================================}
model ResumeMergeRecord {
  id             String @id @default(uuid())
  mainResumeId   String // 主简历（保留）
  mergedResumeId String // 被合并简历

  mergeType String // MANUAL(主动合并), AUTO(超时自动合并)

  operatorId  String?
  mergeReason String?

  createdAt DateTime @default(now())

  mainResume   Resume @relation("MainResumeMerge", fields: [mainResumeId], references: [id], onDelete: Cascade)
  mergedResume Resume @relation("MergedResumeMerge", fields: [mergedResumeId], references: [id], onDelete: Cascade)

  @@unique([mergedResumeId])
  @@index([operatorId])
  @@map("resume_merge_records")
}

// ============================================
// 特殊审批流程表
// ============================================}
model SpecialApprovalFlow {
  id String @id @default(uuid())

  resumeId   String
  positionId String // 审批针对的职位

  flowType String @default("SPECIAL_RESUME") @db.VarChar(32) // SPECIAL_RESUME, OTHER

  status String @default("PENDING") @db.VarChar(32) // PENDING, APPROVED, REJECTED, CANCELLED

  currentNodeId String?

  // 各节点审批信息，JSON格式
  // [{nodeId, nodeName, approverId, approverName, status, comment, decidedAt}]
  nodes String @db.Text // JSON数组

  // 审批结果
  result        String?
  resultComment String?
  decidedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId, status])
  @@index([currentNodeId])
  @@map("special_approval_flows")
}

// ============================================
// 异步评分任务表
// ============================================}
model AsyncScoringTask {
  id String @id @default(uuid())

  resumeId   String
  positionId String // 评分针对的职位

  status String @default("PENDING") @db.VarChar(32) // PENDING, PROCESSING, COMPLETED, FAILED

  matchScore   Int?
  matchDetails String? @db.Text // JSON，评分详情

  errorMessage String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId, status])
  @@map("async_scoring_tasks")
}

// ============================================
// 简历流转日志表
// ============================================}
model ResumeFlowLog {
  id String @id @default(uuid())

  resumeId    String
  candidateId String

  action String // UPLOAD, ASSIGN, ARCHIVE, ACTIVATE, MERGE, SCORE, APPROVE, REJECT

  operatorId   String?
  operatorName String?

  fromStatus String?
  toStatus   String?

  positionId   String? // 关联职位（如果是分配相关）
  positionName String?

  detail String? @db.Text // JSON，额外详情

  createdAt DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@index([candidateId])
  @@index([operatorId])
  @@map("resume_flow_logs")
}

// ============================================
// 系统基础模块
// ============================================
model User {
  id           String    @id @default(uuid())
  username     String    @unique
  password     String
  realName     String
  email        String?   @unique
  phone        String?   @unique
  avatar       String?
  status       String    @default("ACTIVE") @db.VarChar(32)
  roleType     String    @default("HR") @db.VarChar(32)
  departmentId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  wechatWorkUserId String?
  wechatWorkDeptId String?
  wechatWorkName   String?

  mochaUserId String?
  mochaDeptId String?
  mochaName   String?

  permissionMode String @default("MOU") @db.VarChar(32)

  department Department? @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  userRoles           UserRole[]
  userDataPermissions UserDataPermission[]
  userMous            UserMou[]
  userContainers      UserContainer[]
  permissionAuditLogs PermissionAuditLog[]

  // 简历锁定关联
  lockedResumes ResumeLockRecord[] @relation("ResumeLocker")

  assignedCandidates Candidate[] @relation("CandidateAssignedUser")
  providedCandidates Candidate[] @relation("CandidateResumeProvider")

  // 内推门户 Phase 1 - 反向关系
  referralCode         ReferralCode?           @relation("UserReferralCode")
  referralExpertConfigs ReferralExpertConfig[] @relation("UserExpertConfigs")
  expertConfigs        ReferralExpertConfig[]  @relation("ExpertConfigs")
  referrerRecords      ReferralRecord[]        @relation("ReferrerRecords")
  expertRecords        ReferralRecord[]        @relation("ExpertRecords")
  rewardConfirmations  ReferralReward[]        @relation("RewardConfirmer")
  createdReferralRules ReferralRule[]          @relation("RuleCreator")

  @@index([departmentId])
  @@index([wechatWorkUserId])
  @@index([wechatWorkDeptId])
  @@index([mochaUserId])
  @@index([mochaDeptId])
  @@map("users")
}

model Department {
  id         String   @id @default(uuid())
  name       String
  code       String   @unique
  parentId   String?
  level      Int      @default(1)
  path       String
  managerId  String?
  manager2Id String?
  manager3Id String?
  hrbpId     String?
  status     String   @default("ACTIVE") @db.VarChar(32)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  parent   Department?  @relation("DepartmentTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Department[] @relation("DepartmentTree")

  users     User[]
  demands   Demand[]
  positions Position[]

  // 内推门户 Phase 1 - 反向关系
  expertConfigs ReferralExpertConfig[] @relation("TeamExpertConfigs")
  referralTeam  ReferralTeam?          @relation("DepartmentReferralTeam")

  @@index([parentId])
  @@index([managerId])
  @@index([manager2Id])
  @@index([manager3Id])
  @@index([hrbpId])
  @@map("departments")
}

model RecruitmentProcess {
  id              String   @id @default(uuid())
  name            String
  code            String   @unique
  description     String?  @db.Text
  applicableRange String?
  status          String   @default("ACTIVE") @db.VarChar(32)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stages    RecruitmentStage[]
  positions Position[]

  @@map("recruitment_processes")
}

model RecruitmentStage {
  id                String   @id @default(uuid())
  processId         String
  name              String
  code              String
  stageType         String   @db.VarChar(32)
  sortOrder         Int      @default(0)
  stageLimit        Int?
  isDefault         Boolean  @default(true)
  optionalFeatures  String?
  autoFlowCondition String?
  autoFlowTiming    Int?
  status            String   @default("ACTIVE") @db.VarChar(32)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  process RecruitmentProcess @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@unique([processId, code])
  @@index([processId])
  @@map("recruitment_stages")
}

model Demand {
  id             String @id @default(uuid())
  code           String @unique
  name           String
  departmentId   String
  positionCount  Int    @default(1)
  hiredCount     Int    @default(0)
  onBoardCount   Int    @default(0)
  demandType     String @db.VarChar(32)
  demandStatus   String @default("DRAFT") @db.VarChar(32)
  approvalStatus String @default("NOT_STARTED") @db.VarChar(32)

  creatorId       String
  managerId       String?
  assistantIds    String?
  managerIds      String?
  managerSuperIds String?
  hrbpId          String?

  positionSeries String?   @db.VarChar(32)
  jobTitle       String?
  jobLevel       String?   @db.VarChar(32)
  startDate      DateTime?
  endDate        DateTime?

  salaryMin Int?
  salaryMax Int?

  description  String? @db.Text
  requirements String? @db.Text
  attachments  String? @db.Text

  trialGoals String?

  talentLevel String? @db.VarChar(32)
  isDoubleA   Boolean @default(false)

  biddingMode         String   @default("BIDDING") @db.VarChar(32)
  biddingAmount       Decimal? @db.Decimal(12, 2)
  biddingUnit         String?  @db.VarChar(32)
  biddingTalentLevels String?

  status    String   @default("ACTIVE") @db.VarChar(32)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id])

  positions Position[]

  @@index([departmentId])
  @@index([creatorId])
  @@index([managerId])
  @@index([hrbpId])
  @@map("demands")
}

model Position {
  id           String  @id @default(uuid())
  code         String  @unique
  name         String
  departmentId String
  demandId     String?

  creatorId       String
  managerId       String?
  assistantIds    String?
  managerIds      String?
  managerSuperIds String?

  priority       Int     @default(0)
  positionNature String? @db.VarChar(32)
  positionSeries String? @db.VarChar(32)
  description    String? @db.Text
  requirements   String? @db.Text

  processId String?
  companyId String?

  positionStatus String @default("RECRUITING") @db.VarChar(32)
  status         String @default("ACTIVE") @db.VarChar(32)

  candidateCount Int @default(0)
  hiredCount     Int @default(0)

  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  department Department          @relation(fields: [departmentId], references: [id])
  demand     Demand?             @relation(fields: [demandId], references: [id])
  process    RecruitmentProcess? @relation(fields: [processId], references: [id])

  applications Application[]
  channels     PositionChannel[]

  // 内推门户 Phase 1 - 反向关系
  referralRecords ReferralRecord[] @relation("PositionReferrals")

  @@index([departmentId])
  @@index([demandId])
  @@index([creatorId])
  @@index([managerId])
  @@index([processId])
  @@index([companyId])
  @@map("positions")
}

model PositionChannel {
  id             String    @id @default(uuid())
  positionId     String
  channelType    String    @db.VarChar(32)
  channelAccount String?
  publishStatus  String    @default("NOT_PUBLISHED")
  publishUrl     String?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([positionId])
  @@map("position_channels")
}

model Candidate {
  id       String    @id @default(uuid())
  code     String    @unique
  name     String
  gender   String?   @db.VarChar(32)
  birthday DateTime?
  phone    String?
  email    String?

  householdLocation String?
  originLocation    String?

  maritalStatus            String? @db.VarChar(32)
  childStatus              String? @db.VarChar(32)
  highestEducation         String?
  firstEducation           String?
  firstEducationDuration   Int?
  firstEducationSchoolType String?

  workExperience  String?
  jobHoppingRate  Int?
  lastJobDuration Int?

  educationForm     String?   @db.VarChar(32)
  expectedSalaryMin Int?
  expectedSalaryMax Int?
  expectedPosition  String?
  intendedJoinDate  DateTime?

  channelSource   String?
  channelLink     String?
  recommenderId   String?
  recommenderName String?

  assignedUserId   String?
  resumeProviderId String?

  assignedUser   User? @relation("CandidateAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  resumeProvider User? @relation("CandidateResumeProvider", fields: [resumeProviderId], references: [id], onDelete: SetNull)

  candidateStatus String  @default("ACTIVE") @db.VarChar(32)
  archiveReason   String?
  archiveType     String? @db.VarChar(32)
  archiveToPool   String?

  protectionExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumes      Resume[]
  applications Application[]

  // 内推门户 Phase 1 - 反向关系
  referralRecords ReferralRecord[] @relation("CandidateReferrals")
  referralRewards ReferralReward[] @relation("CandidateReferralRewards")

  @@index([recommenderId])
  @@index([assignedUserId])
  @@index([resumeProviderId])
  @@map("candidates")
}

model Resume {
  id          String  @id @default(uuid())
  candidateId String
  positionId  String?

  name     String
  fileName String
  filePath String
  fileType String
  fileSize Int

  parsedData String? @db.Text

  source         String  @db.VarChar(32)
  uploadLocation String?
  providerId     String? // 提供人ID
  uploaderId     String? // 上传人ID
  channelSource  String?
  channelLink    String?

  resumeStatus    String  @default("PENDING_ASSIGN") @db.VarChar(32) // 待分配/已分配/已归档/已删除
  resumeSubStatus String? // 子状态：SCORING(评分中), APPROVAL(审批中), SUSPECTED(疑似)
  parseStatus     String  @default("PENDING") @db.VarChar(32)
  duplicateStatus String  @default("NOT_DUPLICATE") @db.VarChar(32)
  duplicateOfId   String?

  // 锁定人信息（冗余存储，便于查询）
  formalLockerId       String?
  tempLockerId         String?
  tempLockerExpireTime DateTime?

  matchScore Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // 新增关联
  lockRecords   ResumeLockRecord[]
  specialTags   SpecialResumeTag[]
  mergeRecords  ResumeMergeRecord[]   @relation("MainResumeMerge")
  mergedTo      ResumeMergeRecord?    @relation("MergedResumeMerge")
  scoringTasks  AsyncScoringTask[]
  flowLogs      ResumeFlowLog[]
  approvalFlows SpecialApprovalFlow[]

  // 内推门户 Phase 1 - 反向关系
  referralRecords ReferralRecord[] @relation("ResumeReferrals")

  @@index([candidateId])
  @@index([positionId])
  @@index([duplicateOfId])
  @@index([formalLockerId])
  @@index([tempLockerId])
  @@map("resumes")
}

model Application {
  id          String  @id @default(uuid())
  code        String  @unique
  candidateId String
  positionId  String
  resumeId    String?

  currentStageId     String?
  currentStageName   String?
  currentStageStatus String  @default("IN_PROGRESS")

  processId   String
  processName String

  source         String?

  applicationStatus String    @default("ACTIVE") @db.VarChar(32)
  archiveReason     String?
  archivedAt        DateTime?

  // 锁定人（冗余）
  formalLockerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  position  Position  @relation(fields: [positionId], references: [id])

  interviews Interview[]
  offer      Offer?
  onboarding Onboarding?
  invitation InvitationRecord?

  // 内推门户 Phase 1 - 反向关系
  referralRecord ReferralRecord? @relation("ApplicationReferrals")

  @@index([candidateId])
  @@index([positionId])
  @@index([resumeId])
  @@index([currentStageId])
  @@index([processId])
  @@index([formalLockerId])
  @@map("applications")
}

model Interview {
  id            String  @id @default(uuid())
  applicationId String
  roundId       String?
  roundName     String?

  interviewType String   @db.VarChar(32)
  interviewDate DateTime
  duration      Int      @default(60)
  location      String?
  meetingLink   String?

  interviewerIds   String?
  interviewerNames String?

  arrangerId   String
  arrangerName String

  interviewStatus String @default("SCHEDULED") @db.VarChar(32)
  feedbackStatus  String @default("PENDING") @db.VarChar(32)

  cancelReason String?
  cancelNote   String?

  proposedTimes String?
  confirmedTime DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  feedbacks InterviewFeedback[]

  @@index([applicationId])
  @@index([roundId])
  @@index([arrangerId])
  @@map("interviews")
}

model InterviewFeedback {
  id              String @id @default(uuid())
  interviewId     String
  interviewerId   String
  interviewerName String

  result String  @db.VarChar(32)
  reason String?

  values         String?
  comprehensive  String?
  recommendation String?

  participantFeedback String?
  previousFeedback    String?

  viewedPrevious Boolean @default(false)

  feedbackAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@unique([interviewId, interviewerId])
  @@index([interviewId])
  @@index([interviewerId])
  @@map("interview_feedbacks")
}

model Offer {
  id            String @id @default(uuid())
  applicationId String @unique

  demandId          String?
  positionSeries    String? @db.VarChar(32)
  positionManagerId String?
  offerManagerId    String?

  expectedJoinDate   DateTime
  reportLocation     String?
  workLocation       String?
  onboardDepartment  String?
  isDoubleDepartment Boolean  @default(false)

  jobTitle      String?
  jobLevel      String? @db.VarChar(32)
  directLeader  String?
  thoughtLeader String?
  dottedLeader  String?

  employeeType   String? @db.VarChar(32)
  businessType   String? @db.VarChar(32)
  talentLevel    String? @db.VarChar(32)
  costSharing    Boolean @default(false)
  trialMonths    Int?
  contractType   String? @db.VarChar(32)
  contractPeriod String?
  legalCompany   String?

  lastYearAvgSalary     Decimal? @db.Decimal(12, 2)
  salaryPlan            String?
  baseSalaryTrial       Decimal? @db.Decimal(12, 2)
  baseSalaryFormal      Decimal? @db.Decimal(12, 2)
  levelSalaryTrial      Decimal? @db.Decimal(12, 2)
  levelSalaryFormal     Decimal? @db.Decimal(12, 2)
  performanceTrial      Decimal? @db.Decimal(12, 2)
  performanceFormal     Decimal? @db.Decimal(12, 2)
  housingSubsidyTrial   Decimal? @db.Decimal(12, 2)
  housingSubsidyFormal  Decimal? @db.Decimal(12, 2)
  attendanceBonusTrial  Decimal? @db.Decimal(12, 2)
  attendanceBonusFormal Decimal? @db.Decimal(12, 2)
  commissionTrial       Decimal? @db.Decimal(12, 2)
  commissionFormal      Decimal? @db.Decimal(12, 2)

  attachments String? @db.Text

  offerStatus String @default("NOT_CREATED") @db.VarChar(32)

  sentAt   DateTime?
  senderId String?
  ccUsers  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  candidateFeedback     CandidateOfferFeedback?
  backgroundCheckRecord BackgroundCheckRecord[]

  @@index([demandId])
  @@index([positionManagerId])
  @@index([offerManagerId])
  @@index([senderId])
  @@map("offers")
}

model BackgroundCheckRecord {
  id             String    @id @default(uuid())
  offerId        String
  checkType      String
  result         String?
  report         String?
  note           String?
  supplier       String?
  orderedAt      DateTime?
  authorizedAt   DateTime?
  completedAt    DateTime?
  status         String    @default("ACTIVE") @db.VarChar(32)
  isSupplement   Boolean   @default(false)
  supplementOfId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@index([supplementOfId])
  @@map("background_check_records")
}

model CandidateOfferFeedback {
  id          String    @id @default(uuid())
  offerId     String    @unique
  feedback    String    @db.VarChar(32)
  respondedAt DateTime?

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@map("candidate_offer_feedbacks")
}

model Onboarding {
  id            String @id @default(uuid())
  applicationId String @unique

  demandId          String?
  positionSeries    String? @db.VarChar(32)
  positionManagerId String?
  offerManagerId    String?

  expectedJoinDate   DateTime
  reportLocation     String?
  workLocation       String?
  onboardDepartment  String?
  isDoubleDepartment Boolean  @default(false)

  jobTitle      String?
  jobLevel      String? @db.VarChar(32)
  directLeader  String?
  thoughtLeader String?
  dottedLeader  String?

  employeeType      String?  @db.VarChar(32)
  businessType      String?  @db.VarChar(32)
  talentLevel       String?  @db.VarChar(32)
  costSharing       Boolean  @default(false)
  trialMonths       Int?
  contractType      String?  @db.VarChar(32)
  contractPeriod    String?
  legalCompany      String?
  lastYearAvgSalary Decimal? @db.Decimal(12, 2)

  referrerId     String?
  officeSupplies String?

  salaryPlan            String?
  baseSalaryTrial       Decimal? @db.Decimal(12, 2)
  baseSalaryFormal      Decimal? @db.Decimal(12, 2)
  levelSalaryTrial      Decimal? @db.Decimal(12, 2)
  levelSalaryFormal     Decimal? @db.Decimal(12, 2)
  performanceTrial      Decimal? @db.Decimal(12, 2)
  performanceFormal     Decimal? @db.Decimal(12, 2)
  housingSubsidyTrial   Decimal? @db.Decimal(12, 2)
  housingSubsidyFormal  Decimal? @db.Decimal(12, 2)
  attendanceBonusTrial  Decimal? @db.Decimal(12, 2)
  attendanceBonusFormal Decimal? @db.Decimal(12, 2)
  commissionTrial       Decimal? @db.Decimal(12, 2)
  commissionFormal      Decimal?

  attachments String? @db.Text

  onboardingStatus String  @default("NOT_STARTED") @db.VarChar(32)
  approvalStatus   String  @default("NOT_STARTED") @db.VarChar(32)
  approvalRecordId String?

  peopleOnboardId String?
  syncStatus      String? @db.VarChar(32)
  cancelReason    String?
  cancelNote      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([demandId])
  @@index([positionManagerId])
  @@index([offerManagerId])
  @@index([referrerId])
  @@index([approvalRecordId])
  @@index([peopleOnboardId])
  @@map("onboardings")
}

model InvitationRecord {
  id            String @id @default(uuid())
  applicationId String @unique

  candidateId String
  positionId  String

  ownerId   String
  ownerName String

  inviterId   String?
  inviterName String?

  assignType String    @db.VarChar(32)
  assignedAt DateTime?

  invitationStatus String @default("PENDING_ASSIGN") @db.VarChar(32)

  claimedAt     DateTime?
  claimedById   String?
  claimedByName String?

  contactAttempts Int       @default(0)
  lastContactAt   DateTime?

  tags String?
  note String?

  interventionCount  Int     @default(0)
  lastInterventionBy String?

  biddingAmount Decimal? @db.Decimal(12, 2)

  resultStatus String?   @db.VarChar(32)
  resultReason String?
  resultAt     DateTime?

  timeoutAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([positionId])
  @@index([ownerId])
  @@index([inviterId])
  @@index([claimedById])
  @@map("invitation_records")
}

model Notification {
  id         String    @id @default(uuid())
  userId     String
  type       String    @db.VarChar(32)
  title      String
  content    String    @db.Text
  data       String?
  readStatus String    @default("UNREAD") @db.VarChar(32)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("notifications")
}

model OperationRecord {
  id            String   @id @default(uuid())
  userId        String
  userName      String
  operationType String   @db.VarChar(32)
  targetType    String
  targetId      String
  targetName    String?
  detail        String?
  beforeValue   String?
  afterValue    String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([targetId])
  @@map("operation_records")
}

model Dictionary {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?  @db.Text
  status      String   @default("ACTIVE") @db.VarChar(32)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items DictionaryItem[]

  @@map("dictionaries")
}

model DictionaryItem {
  id           String   @id @default(uuid())
  dictionaryId String
  parentId     String?
  name         String
  code         String
  value        String?
  description  String?  @db.Text
  sortOrder    Int      @default(0)
  level        Int      @default(1)
  status       String   @default("ACTIVE") @db.VarChar(32)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dictionary Dictionary       @relation(fields: [dictionaryId], references: [id], onDelete: Cascade)
  parent     DictionaryItem?  @relation("DictionaryItemTree", fields: [parentId], references: [id], onDelete: Restrict)
  children   DictionaryItem[] @relation("DictionaryItemTree")

  @@unique([dictionaryId, code])
  @@index([dictionaryId])
  @@index([parentId])
  @@map("dictionary_items")
}

model Company {
  id              String   @id @default(uuid())
  name            String
  code            String   @unique
  parentCompanyId String?
  isBenchmark     Boolean  @default(false)
  industry        String?
  scale           String?  @db.VarChar(32)
  description     String?  @db.Text
  status          String   @default("ACTIVE") @db.VarChar(32)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parentCompany  Company?  @relation("CompanyGroup", fields: [parentCompanyId], references: [id], onDelete: Restrict)
  childCompanies Company[] @relation("CompanyGroup")

  @@index([parentCompanyId])
  @@map("companies")
}

model School {
  id             String   @id @default(uuid())
  name           String
  code           String   @unique
  location       String?
  province       String?
  city           String?
  educationLevel String?  @db.VarChar(32)
  schoolType     String?  @db.VarChar(32)
  schoolCategory String?  @db.VarChar(32)
  status         String   @default("ACTIVE") @db.VarChar(32)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("schools")
}

model CompanyAddress {
  id           String   @id @default(uuid())
  name         String
  country      String   @default("中国")
  province     String
  city         String
  district     String?
  address      String
  longitude    Float?
  latitude     Float?
  isLocated    Boolean  @default(false)
  contactPhone String?
  contactEmail String?
  companyType  String?  @db.VarChar(32)
  status       String   @default("ACTIVE") @db.VarChar(32)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("company_addresses")
}

model ScoringRule {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?  @db.Text
  ruleType    String   @db.VarChar(32)
  status      String   @default("ACTIVE") @db.VarChar(32)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applicableRange String?

  conditions ScoringCondition[]
  results    ScoringResult[]

  @@map("scoring_rules")
}

model ScoringCondition {
  id        String @id @default(uuid())
  ruleId    String
  field     String
  operator  String
  value     String
  level     Int    @default(1)
  logicType String @default("AND")

  rule ScoringRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  results ScoringResult[]

  @@index([ruleId])
  @@map("scoring_conditions")
}

model ScoringResult {
  id             String  @id @default(uuid())
  ruleId         String
  conditionId    String?
  field          String?
  matchedScore   Int
  unmatchedScore Int     @default(0)
  isDefault      Boolean @default(false)

  rule      ScoringRule       @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  condition ScoringCondition? @relation(fields: [conditionId], references: [id], onDelete: SetNull)

  @@index([ruleId])
  @@index([conditionId])
  @@map("scoring_results")
}

// ============================================
// 权限管理模块 (V2.0)
// ============================================
model Role {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?  @db.Text
  roleType    String
  status      String   @default("ACTIVE") @db.VarChar(32)
  sortOrder   Int      @default(0)
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id             String  @id @default(uuid())
  name           String
  code           String  @unique
  permissionType String  @db.VarChar(32)
  resource       String?
  action         String?
  dataScope      String?

  parentId String?
  level    Int     @default(1)
  path     String?

  description String? @db.Text
  status      String  @default("ACTIVE") @db.VarChar(32)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Permission?  @relation("PermissionTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Permission[] @relation("PermissionTree")

  rolePermissions RolePermission[]

  @@index([parentId])
  @@map("permissions")
}

model RolePermission {
  id           String  @id @default(uuid())
  roleId       String
  permissionId String
  grantType    String  @default("GRANT") @db.VarChar(32)
  conditions   String?

  createdAt DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId, grantType])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String    @id @default(uuid())
  userId    String
  roleId    String
  scope     String?
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("ACTIVE") @db.VarChar(32)

  createdAt DateTime @default(now())
  createdBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model DataPermissionRule {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique
  description String?

  permissionType String  @db.VarChar(32)
  ruleScope      String  @db.VarChar(32)
  ruleExpression String?

  roleIds String?

  priority Int @default(0)

  status    String   @default("ACTIVE") @db.VarChar(32)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userDataPermissions UserDataPermission[]

  @@map("data_permission_rules")
}

model UserDataPermission {
  id     String @id @default(uuid())
  userId String
  ruleId String

  customScope String?
  deptIds     String?
  userIds     String?

  startDate DateTime?
  endDate   DateTime?

  status    String   @default("ACTIVE") @db.VarChar(32)
  createdAt DateTime @default(now())

  user User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule DataPermissionRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([userId, ruleId])
  @@index([userId])
  @@index([ruleId])
  @@map("user_data_permissions")
}

model Mou {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique
  type        String  @db.VarChar(32)
  description String? @db.Text

  parentMouId String?
  level       Int     @default(1)
  path        String?

  metadata String?

  status    String    @default("ACTIVE") @db.VarChar(32)
  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Mou?  @relation("MouTree", fields: [parentMouId], references: [id], onDelete: Restrict)
  children Mou[] @relation("MouTree")

  userMous   UserMou[]
  containers PermissionContainer[]

  @@index([parentMouId])
  @@map("mous")
}

model UserMou {
  id     String @id @default(uuid())
  userId String
  mouId  String

  roleInMou String?

  startDate DateTime?
  endDate   DateTime?

  status    String   @default("ACTIVE") @db.VarChar(32)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  mou  Mou  @relation(fields: [mouId], references: [id], onDelete: Cascade)

  @@unique([userId, mouId])
  @@index([userId])
  @@index([mouId])
  @@map("user_mous")
}

model PermissionContainer {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique
  type        String  @db.VarChar(32)
  description String? @db.Text

  mouId          String?
  resourceFilter String?

  status String @default("ACTIVE") @db.VarChar(32)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mou Mou? @relation(fields: [mouId], references: [id], onDelete: SetNull)

  userContainers     UserContainer[]
  containerResources ContainerResource[]

  @@index([mouId])
  @@map("permission_containers")
}

model UserContainer {
  id          String @id @default(uuid())
  userId      String
  containerId String

  accessLevel String?

  startDate DateTime?
  endDate   DateTime?

  status    String   @default("ACTIVE") @db.VarChar(32)
  createdAt DateTime @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  container PermissionContainer @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@unique([userId, containerId])
  @@index([userId])
  @@index([containerId])
  @@map("user_containers")
}

model ContainerResource {
  id           String @id @default(uuid())
  containerId  String
  resourceType String @db.VarChar(32)
  resourceId   String

  createdAt DateTime @default(now())

  container PermissionContainer @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@unique([containerId, resourceType, resourceId])
  @@index([containerId])
  @@index([resourceId])
  @@map("container_resources")
}

model AutomationRule {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique
  description String? @db.Text

  eventType String

  condition String?

  actions String

  priority Int @default(0)

  status String @default("ACTIVE") @db.VarChar(32)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  executionLogs AutomationLog[]

  @@map("automation_rules")
}

model AutomationLog {
  id     String @id @default(uuid())
  ruleId String

  triggerUserId String?
  triggerEvent  String?

  executedActions String?

  result String?

  errorMessage String?

  executedAt DateTime @default(now())

  rule AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([triggerUserId])
  @@map("automation_logs")
}

model MutualExclusionGroup {
  id          String  @id @default(uuid())
  name        String
  description String?

  roleIds String

  status String @default("ACTIVE") @db.VarChar(32)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("mutual_exclusion_groups")
}

model PermissionAuditLog {
  id       String  @id @default(uuid())
  userId   String
  userName String?

  action     String  @db.VarChar(32)
  targetType String
  targetId   String
  targetName String?

  source       String  @db.VarChar(32)
  operatorId   String?
  operatorName String?

  detail String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([targetId])
  @@index([operatorId])
  @@map("permission_audit_logs")
}

// ============================================
// 内推门户 - Phase 1 (地基层)
// ============================================

model ReferralCode {
  id            String   @id @default(uuid())
  code          String   @unique @db.VarChar(16)
  userId        String   @unique
  status        String   @default("ACTIVE") @db.VarChar(32)
  invalidReason String?  @db.VarChar(64)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User               @relation("UserReferralCode", fields: [userId], references: [id], onDelete: Cascade)
  records ReferralRecord[]
  configs ReferralExpertConfig[]

  @@index([status])
  @@map("referral_codes")
}

model ReferralExpertConfig {
  id        String   @id @default(uuid())
  userId    String
  teamId    String
  expertId  String
  referralCodeId String?
  isPrimary Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation("UserExpertConfigs", fields: [userId], references: [id], onDelete: Cascade)
  team         Department    @relation("TeamExpertConfigs", fields: [teamId], references: [id], onDelete: Restrict)
  expert       User          @relation("ExpertConfigs", fields: [expertId], references: [id], onDelete: Restrict)
  referralCode ReferralCode? @relation(fields: [referralCodeId], references: [id], onDelete: SetNull)

  @@unique([userId, teamId, expertId])
  @@index([userId])
  @@index([expertId])
  @@index([teamId])
  @@index([referralCodeId])
  @@map("referral_expert_configs")
}

model ReferralTeam {
  id          String   @id @default(uuid())
  teamId      String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team Department @relation("DepartmentReferralTeam", fields: [teamId], references: [id], onDelete: Cascade)

  @@map("referral_teams")
}

model ReferralRecord {
  id              String   @id @default(uuid())
  referrerId      String
  referrerCode    String   @db.VarChar(16)
  candidateId     String
  resumeId        String?
  positionId      String
  expertId        String
  referralCodeId  String?
  referralType    String   @db.VarChar(32)
  referralStatus  String   @default("NORMAL") @db.VarChar(32)
  protectionEndAt DateTime?
  invalidReason   String?  @db.VarChar(64)
  recommendedAt   DateTime @default(now())
  statusChangedAt DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  referrer  User        @relation("ReferrerRecords", fields: [referrerId], references: [id], onDelete: Restrict)
  candidate Candidate   @relation("CandidateReferrals", fields: [candidateId], references: [id], onDelete: Cascade)
  resume    Resume?     @relation("ResumeReferrals", fields: [resumeId], references: [id], onDelete: SetNull)
  position  Position    @relation("PositionReferrals", fields: [positionId], references: [id], onDelete: Restrict)
  expert    User        @relation("ExpertRecords", fields: [expertId], references: [id], onDelete: Restrict)
  referralCode ReferralCode? @relation(fields: [referralCodeId], references: [id], onDelete: SetNull)
  applicationId String?      @unique
  application   Application? @relation("ApplicationReferrals", fields: [applicationId], references: [id], onDelete: SetNull)
  rewards   ReferralReward[]

  @@unique([candidateId, positionId, referrerId], name: "uniq_candidate_position_referrer")
  @@index([referrerId, referralStatus])
  @@index([expertId, referralStatus])
  @@index([positionId])
  @@index([protectionEndAt])
  @@index([referralStatus, statusChangedAt])
  @@index([referralCodeId])
  @@map("referral_records")
}

model ReferralReward {
  id           String   @id @default(uuid())
  recordId     String
  candidateId  String
  amount       Decimal  @db.Decimal(10, 2)
  reason       String   @db.VarChar(64)
  triggerStage String   @db.VarChar(32)
  status       String   @default("PENDING") @db.VarChar(32)
  ruleId       String?
  triggeredAt  DateTime @default(now())
  confirmedBy  String?
  confirmedAt  DateTime?
  issuedAt     DateTime?
  rejectedAt   DateTime?
  rejectReason String?  @db.VarChar(255)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  record    ReferralRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  candidate Candidate      @relation("CandidateReferralRewards", fields: [candidateId], references: [id], onDelete: Cascade)
  rule      ReferralRule?  @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  confirmer User?          @relation("RewardConfirmer", fields: [confirmedBy], references: [id], onDelete: SetNull)

  @@index([recordId])
  @@index([status])
  @@index([triggeredAt])
  @@index([candidateId])
  @@map("referral_rewards")
}

model ReferralRule {
  id            String   @id @default(uuid())
  name          String   @unique @db.VarChar(64)
  ruleType      String   @db.VarChar(32)
  positionLevel String?  @db.VarChar(32)
  triggerStage  String?  @db.VarChar(32)
  conditions    Json
  amount        Decimal? @db.Decimal(10, 2)
  status        String   @default("ACTIVE") @db.VarChar(32)
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creator User             @relation("RuleCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  rewards ReferralReward[]

  @@index([ruleType, status])
  @@map("referral_rules")
}
