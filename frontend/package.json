{
  "name": "ats-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vue-tsc && vite build",
    "build:nocheck": "vite build",
    "analyze": "ANALYZE=1 vue-tsc && ANALYZE=1 vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@vicons/ionicons5": "^0.13.0",
    "@vueuse/core": "^10.7.0",
    "axios": "^1.6.0",
    "dayjs": "^1.11.0",
    "naive-ui": "^2.44.1",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^20.19.39",
    "@unocss/reset": "^66.7.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^15.11.7",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.3.0",
    "unocss": "^66.7.0",
    "vite": "^5.0.0",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.2.12"
  }
}
