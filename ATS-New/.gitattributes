# Ensure consistent line endings
*               text=auto eol=lf

# Python
*.py            text eol=lf
*.pyi           text eol=lf

# Web
*.js            text eol=lf
*.ts            text eol=lf
*.tsx           text eol=lf
*.vue           text eol=lf
*.json          text eol=lf
*.css           text eol=lf
*.scss          text eol=lf
*.html          text eol=lf

# Docs
*.md            text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf

# Shell
*.sh            text eol=lf
Makefile        text eol=lf

# Binary
*.png           binary
*.jpg           binary
*.gif           binary
*.ico           binary
*.woff          binary
*.woff2         binary
