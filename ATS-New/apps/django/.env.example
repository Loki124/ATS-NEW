# Django
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
# 生产环境使用 MySQL，开发环境可使用 SQLite
DATABASE_URL=mysql://ats_user:ats_password@localhost:3306/ats_db
# 备选 PostgreSQL
# DATABASE_URL=postgres://ats_user:ats_password@localhost:5432/ats_db
# 备选 SQLite（本地开发）
# DATABASE_URL=sqlite:///db.sqlite3

# Redis (Celery broker + cache + Channels)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# 限流
RATELIMIT_ENABLE=True

# 通知
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=your-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# 企微
WECOM_CORPID=your-corpid
WECOM_CORPSECRET=your-corpsecret
WECOM_AGENTID=your-agentid

# 短信
SMS_PROVIDER=mock
SMS_API_KEY=your-key

# 外部集成
MOKA_API_URL=https://api.moka.example.com
MOKA_API_KEY=your-key

# 监控
SENTRY_DSN=
PROMETHEUS_ENABLED=False

# 日志
LOG_LEVEL=INFO
